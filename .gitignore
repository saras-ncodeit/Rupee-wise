# =============================================================================
# Rupee-wise — Monorepo .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Environment Variables (NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/

# -----------------------------------------------------------------------------
# Backend — NestJS / Prisma
# -----------------------------------------------------------------------------
backend/dist/
backend/coverage/

# Prisma
backend/prisma/*.db
backend/prisma/*.db-journal
backend/prisma/*.db-shm
backend/prisma/*.db-wal

# -----------------------------------------------------------------------------
# Frontend — Vite / React
# -----------------------------------------------------------------------------
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# OS — macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# -----------------------------------------------------------------------------
# OS — Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Editors — VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# -----------------------------------------------------------------------------
# Editors — JetBrains / IntelliJ / WebStorm
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr

# -----------------------------------------------------------------------------
# Editors — General
# -----------------------------------------------------------------------------
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
