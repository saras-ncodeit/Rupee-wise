datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String?
  fullName          String
  avatarUrl         String?
  timezone          String             @default("Asia/Kolkata")
  locale            String             @default("en-IN")
  currency          String             @default("INR")
  isEmailVerified   Boolean            @default(false)
  is2faEnabled      Boolean            @default(false)
  totpSecret        String?
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  memberships       HouseholdMember[]
  createdHouseholds Household[]        @relation("CreatedHouseholds")
  transactions      Transaction[]
  attachments       Attachment[]
  createdBudgets    Budget[]
  goalContributions GoalContribution[]
  createdRules      RecurringRule[]
  notifications     Notification[]
  auditLogs         AuditLog[]
}

model Household {
  id           String            @id @default(uuid())
  name         String
  currency     String            @default("INR")
  timezone     String            @default("Asia/Kolkata")
  plan         String            @default("free")
  createdBy    String
  creator      User              @relation("CreatedHouseholds", fields: [createdBy], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  members      HouseholdMember[]
  accounts     Account[]
  budgets      Budget[]
  savingsGoals SavingsGoal[]
  categories   Category[]
  transactions Transaction[]
  loans        Loan[]
  investments  Investment[]
  bills        Bill[]
  rules        RecurringRule[]
  notifications Notification[]
  auditLogs    AuditLog[]
  snapshots    MonthlySnapshot[]
}

model HouseholdMember {
  id           String    @id @default(uuid())
  householdId  String
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String    // owner, co_owner, member, viewer
  displayName  String?
  joinedAt     DateTime  @default(now())
  invitedBy    String?
  
  @@unique([householdId, userId])
}

model Account {
  id                 String        @id @default(uuid())
  householdId        String
  household          Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name               String
  type               String        // checking, savings, credit_card, loan, investment, cash, other
  institution        String?
  accountNumberLast4 String?
  currency           String        @default("INR")
  openingBalance     Decimal       @default(0.00)
  currentBalance     Decimal       @default(0.00)
  isActive           Boolean       @default(true)
  color              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  transactions       Transaction[] @relation("AccountTransactions")
  transfersTo        Transaction[] @relation("TransferToTransactions")
  loans              Loan[]
  investments        Investment[]
  bills              Bill[]
}

model Category {
  id          String       @id @default(uuid())
  householdId String?
  household   Household?   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Category?    @relation("SubCategories", fields: [parentId], references: [id])
  subCategories Category[] @relation("SubCategories")
  name        String
  type        String       // income, expense, transfer
  icon        String?
  color       String?
  isSystem    Boolean      @default(false)
  isArchived  Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  transactions Transaction[]
  splits       TransactionSplit[]
  budgetLines  BudgetLine[]
  bills        Bill[]
  snapshots    MonthlySnapshot[]
}

model Transaction {
  id                   String             @id @default(uuid())
  householdId          String
  household            Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  accountId            String
  account              Account            @relation("AccountTransactions", fields: [accountId], references: [id])
  createdBy            String
  creator              User               @relation(fields: [createdBy], references: [id])
  categoryId           String?
  category             Category?          @relation(fields: [categoryId], references: [id])
  type                 String             // income, expense, transfer
  amount               Decimal
  currency             String             @default("INR")
  exchangeRate         Decimal            @default(1.000000)
  date                 DateTime
  description          String?
  notes                String?
  isRecurring          Boolean            @default(false)
  recurringId          String?
  transferToAccountId String?
  transferToAccount    Account?           @relation("TransferToTransactions", fields: [transferToAccountId], references: [id])
  isReimbursable       Boolean            @default(false)
  reimbursedAt         DateTime?
  isReviewed           Boolean            @default(false)
  loanId               String?
  loan                 Loan?              @relation(fields: [loanId], references: [id])
  billId               String?
  bill                 Bill?              @relation(fields: [billId], references: [id])
  investmentId         String?
  investment           Investment?        @relation(fields: [investmentId], references: [id])
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?
  splits               TransactionSplit[]
  attachments          Attachment[]
  tags                 TransactionTag[]
  contributions        GoalContribution[]
  loanPayments         LoanPayment[]
  billPayments         BillPayment[]
}

model TransactionSplit {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id])
  amount        Decimal
  notes         String?
}

model Tag {
  id          String           @id @default(uuid())
  householdId String
  name        String
  color       String?
  transactions TransactionTag[]
}

model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

model Attachment {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fileName      String
  fileType      String
  fileSize      Int
  storageKey    String
  thumbnailKey  String?
  uploadedAt    DateTime    @default(now())
  uploadedBy    String
  uploader      User        @relation(fields: [uploadedBy], references: [id])
}

model Budget {
  id                 String       @id @default(uuid())
  householdId        String
  household          Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  month              DateTime
  totalIncomeBudget  Decimal?
  notes              String?
  createdBy          String
  creator            User         @relation(fields: [createdBy], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  lines              BudgetLine[]

  @@unique([householdId, month])
}

model BudgetLine {
  id             String   @id @default(uuid())
  budgetId       String
  budget         Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  plannedAmount  Decimal
  rolloverAmount Decimal  @default(0.00)
  isPercentage   Boolean  @default(false)
  percentageValue Decimal?
  alertAtPct     Int      @default(80)
  weeklyOverride Decimal?
}

model SavingsGoal {
  id              String             @id @default(uuid())
  householdId     String
  household       Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name            String
  targetAmount    Decimal
  currentAmount   Decimal            @default(0.00)
  deadline        DateTime?
  icon            String?
  color           String?
  linkedAccountId String?
  status          String             @default("active") // active, paused, completed, abandoned
  createdAt       DateTime           @default(now())
  contributions   GoalContribution[]
}

model GoalContribution {
  id            String      @id @default(uuid())
  goalId        String
  goal          SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  amount        Decimal
  contributedBy String
  contributor   User        @relation(fields: [contributedBy], references: [id])
  contributedAt DateTime    @default(now())
  notes         String?
}

model Loan {
  id                 String        @id @default(uuid())
  householdId        String
  household          Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name               String
  lender             String
  loanType           String
  principalAmount    Decimal
  outstandingBalance Decimal
  interestRate       Decimal
  emiAmount          Decimal?
  emiDay             Int?
  startDate          DateTime
  endDate            DateTime?
  accountId          String?
  account            Account?      @relation(fields: [accountId], references: [id])
  payments           LoanPayment[]
  transactions       Transaction[]
}

model LoanPayment {
  id              String      @id @default(uuid())
  loanId          String
  loan            Loan        @relation(fields: [loanId], references: [id], onDelete: Cascade)
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  paymentDate     DateTime
  principalAmount Decimal
  interestAmount  Decimal
  extraPayment    Decimal     @default(0.00)
}

model Investment {
  id             String        @id @default(uuid())
  householdId    String
  household      Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name           String
  type           String
  units          Decimal?
  buyPrice       Decimal?
  currentPrice   Decimal?
  currentValue   Decimal
  investedAmount Decimal
  accountId      String?
  account        Account?      @relation(fields: [accountId], references: [id])
  lastUpdated    DateTime
  notes          String?
  transactions   Transaction[]
}

model Bill {
  id                String        @id @default(uuid())
  householdId       String
  household         Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name              String
  categoryId        String
  category          Category      @relation(fields: [categoryId], references: [id])
  amount            Decimal
  isVariable        Boolean       @default(false)
  dueDay            Int
  remindDaysBefore  Int           @default(3)
  accountId         String?
  account           Account?      @relation(fields: [accountId], references: [id])
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  payments          BillPayment[]
  transactions      Transaction[]
}

model BillPayment {
  id            String      @id @default(uuid())
  billId        String
  bill          Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  billingPeriod DateTime
  paidAt        DateTime
  amountPaid    Decimal

  @@unique([billId, billingPeriod])
}

model RecurringRule {
  id             String    @id @default(uuid())
  householdId    String
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  templateData   String
  frequency      String
  startDate      DateTime
  endDate        DateTime?
  nextOccurrence DateTime
  isActive       Boolean   @default(true)
  createdBy      String
  creator        User      @relation(fields: [createdBy], references: [id])
}

model Notification {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)
  type        String
  title       String
  body        String
  actionUrl   String?
  isRead      Boolean    @default(false)
  sentAt      DateTime   @default(now())
  readAt      DateTime?
}

model AuditLog {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id], onDelete: SetNull)
  entityType  String
  entityId    String
  action      String
  beforeData  String?
  afterData   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())
}

model MonthlySnapshot {
  id             String    @id @default(uuid())
  householdId    String
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  month          DateTime
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  totalSpent     Decimal   @default(0.00)
  totalIncome    Decimal   @default(0.00)
  budgetedAmount Decimal   @default(0.00)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([householdId, month, categoryId])
}
